# Supabase Configuration
# Copy this file to .env.local and fill in your actual values

NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Optional: Supabase security bypass (e.g. admin)
# SUPABASE_SERVICE_ROLE_KEY=

# Optional: Development overrides
# NODE_ENV=development
# NEXT_TELEMETRY_DISABLED=1

# Optional: Analytics (if you add them later)
# NEXT_PUBLIC_GA_ID=your-ga-id
# NEXT_PUBLIC_GTM_ID=your-gtm-id 

# n8n Webhook Configuration
# Replace with your actual n8n webhook URL for email sending
NEXT_PUBLIC_N8N_WEBHOOK_URL=https://your-n8n-instance.com/webhook/send-email

